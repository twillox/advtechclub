# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (Use MongoDB Atlas for production)
MONGO_URI=mongodb://127.0.0.1:27017/techclub

# JWT Secret (Generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
# For development: *
# For production: your frontend URL (e.g., https://your-app.vercel.app)
CORS_ORIGIN=*

# Frontend URL (optional, for stricter CORS control)
FRONTEND_URL=http://localhost:5173